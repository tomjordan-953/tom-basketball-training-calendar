# CourtSight AI environment variables
# Copy this file to .env.local and fill in values you have.

# Optional. Without it, the app runs in Demo Mode using bundled sample data.
# Get a key at https://www.balldontlie.io/
BALLDONTLIE_API_KEY=

# Public app name (used in UI).
NEXT_PUBLIC_APP_NAME=CourtSight AI

# Provider mode (default: auto)
#   auto         use balldontlie if BALLDONTLIE_API_KEY is set, else Demo
#   demo         force Demo Mode (bundled sample data)
#   balldontlie  force balldontlie (falls back to Demo if API key is missing)
DATA_PROVIDER=auto
